<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mce.scanner</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/mce-scanner</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>/Users/hong/.claude/projects</string>
        <string>/Users/hong/.codex/sessions</string>
        <string>/Users/hong/.grok/sessions</string>
        <string>/Users/hong/.local/share/opencode</string>
    </array>
    <key>StandardOutPath</key>
    <string>/Users/hong/.mce-scanner/scanner.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/hong/.mce-scanner/scanner.err</string>
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
